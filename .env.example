# ===========================================
# Alice AI Agent - Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# ⚠️  NEVER commit .env to version control!

# -------------------------------------------
# AI Provider
# -------------------------------------------
# Alice stores provider configs (including API keys) via the Settings UI.
# API keys are stored in localStorage and synced to ~/.alice/data/ on disk.
# No API keys need to be in environment variables.

# Supported providers (configured in-app):
#   OpenAI, OpenRouter, Anthropic, Google Gemini,
#   Groq, DeepSeek, Together AI, Cohere

# -------------------------------------------
# Agent Backend Server (optional)
# -------------------------------------------
# Only needed when running with `alice --agent` flag

# ALICE_AGENT_PORT=3020
# ALICE_ORIGINS=http://localhost:8082,http://localhost:3020

# -------------------------------------------
# Supabase Cloud Sync (optional)
# -------------------------------------------

# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-anon-key-here
# VITE_SUPABASE_URL=$SUPABASE_URL
# VITE_SUPABASE_PUBLISHABLE_KEY=$SUPABASE_PUBLISHABLE_KEY

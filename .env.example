# ===========================================
# Alice AI Agent - Environment Variables
# ===========================================

# -------------------------------------------
# AI Provider Configuration (choose at least one)
# -------------------------------------------

# OpenAI (GPT-4, GPT-4o, o-series)
OPENAI_API_KEY=sk-your-openai-key-here

# OpenRouter (access to many providers)
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Anthropic (direct API)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# -------------------------------------------
# Agent Backend Server
# -------------------------------------------
# Port for the agent server (default: 3020)
ALICE_AGENT_PORT=3020

# Allowed origins for CORS (comma-separated)
# Allow the frontend dev server to access the agent API
ALICE_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# -------------------------------------------
# Supabase Cloud Sync (optional)
# -------------------------------------------
# Enable cloud backup/sync of Alice data
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbG...your-supabase-publishable-key

# Vite prefixed versions (for client-side)
VITE_SUPABASE_URL=$SUPABASE_URL
VITE_SUPABASE_PUBLISHABLE_KEY=$SUPABASE_PUBLISHABLE_KEY

# -------------------------------------------
# Frontend Development
# -------------------------------------------
# Vite dev server
VITE_ALICE_AGENT_URL=http://localhost:3020
ALICE_AGENT_URL=http://localhost:3020

# -------------------------------------------
# Notes
# -------------------------------------------
# 1. Copy this file to .env and fill in your actual values
# 2. At minimum, you need ONE AI provider API key
# 3. Agent server must be running (npm run dev:agent or npm run agent)
# 4. Cloud sync is optional but recommended for persistence across devices
# 5. Never commit .env to version control!

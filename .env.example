# ===========================================
# Alice AI Agent - Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env

# -------------------------------------------
# AI Provider Configuration (choose at least one)
# -------------------------------------------

# OpenAI (GPT-4, GPT-4o, o-series)
OPENAI_API_KEY=sk-your-openai-key-here

# OpenRouter (access to many providers)
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Anthropic (direct API)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# -------------------------------------------
# Agent Backend Server
# -------------------------------------------

# Port for the agent server API (default: 3020)
ALICE_AGENT_PORT=3020

# Allowed origins for CORS (comma-separated)
# Must include the frontend port for the browser to access the API
ALICE_ORIGINS=http://localhost:8082,http://localhost:3020,http://localhost:5173,http://localhost:3000

# -------------------------------------------
# Frontend (Vite)
# -------------------------------------------

# Port agent server for the frontend to connect to (default: 3020)
VITE_ALICE_AGENT_PORT=3020

# -------------------------------------------
# Supabase Cloud Sync (optional)
# -------------------------------------------
# Enable cloud backup/sync of Alice data across devices

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbG...your-supabase-publishable-key

# Service role key for server-side admin operations (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your-service-role-key

# Vite prefixed versions (for client-side rendering)
VITE_SUPABASE_URL=$SUPABASE_URL
VITE_SUPABASE_PUBLISHABLE_KEY=$SUPABASE_PUBLISHABLE_KEY

# -------------------------------------------
# Notes
# -------------------------------------------
# 1. At minimum, you need ONE AI provider API key
# 2. Run alice to start both agent server (3020) + frontend (8082)
# 3. Cloud sync is optional but recommended for persistence across devices
# 4. Never commit .env to version control!
